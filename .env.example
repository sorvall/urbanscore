# Скопируйте в .env и подставьте ключи.
# DaData — https://dadata.ru/api/
DADATA_BASE_URL=https://suggestions.dadata.ru
DADATA_API_TOKEN=
DADATA_SECRET=
DADATA_ENABLED=true
DADATA_MIN_REQUEST_INTERVAL_MS=0
DADATA_ADDRESS_DIVISION=administrative

# DeepSeek — https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# Опционально (дефолты в application.yml):
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_CONNECT_TIMEOUT=15s
# DEEPSEEK_RESPONSE_TIMEOUT=300s
# Системный промпт (формат ответа): classpath:prompts/deepseek-system-prompt.txt
# DEEPSEEK_SYSTEM_PROMPT_PATH=file:/полный/путь/к/prompt.txt
# DEEPSEEK_SYSTEM_PROMPT=...
# Текст задания отчёта (экспертный промпт): classpath:prompts/deepseek-user-prompt.txt
# DEEPSEEK_USER_PROMPT_PATH=file:/полный/путь/к/user-prompt.txt
# DEEPSEEK_USER_PROMPT=...
# Веб-поиск в API DeepSeek (поле search_enable), по умолчанию true
# DEEPSEEK_ENABLE_SEARCH=true
# Временно: отдавать в API текст тела запроса к DeepSeek для отладки UI (по умолчанию true). В проде: false
# APP_DEBUG_DEEPSEEK_REQUEST=false

# Сборка фронта в docker compose (публичные URL вашего сервера):
# За Caddy с одним доменом оставьте API пустым и пересоберите фронт:
# VITE_API_BASE_URL=
# VITE_SITE_URL=https://example.ru
# CORS: по умолчанию * (см. application.yml). Сузить список: APP_CORS_ORIGINS=https://example.ru,http://IP:5173
# APP_CORS_ORIGINS=*
# HTTPS (Caddy + Let's Encrypt), см. Caddyfile и README:
# CADDY_DOMAIN=example.ru
# SERVER_PORT=8080

# --- Деплой (файл .env на сервере в каталоге DEPLOY_PATH из GitHub Secrets) ---
# Первичная настройка VPS: scripts/server-bootstrap.sh
# Секреты GitHub Actions: scripts/gh-set-deploy-secrets.sh (нужен gh CLI)
