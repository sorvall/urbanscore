# Copy: cp .env.example .env — then put tokens only in .env (gitignored).
# The app service uses env_file: .env so AQICN_API_KEY is read from that file.
# PostgreSQL
POSTGRES_DB=ecorating
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Spring datasource
DB_URL=jdbc:postgresql://postgres:5432/ecorating
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TIMEOUT=3s

# External APIs
AQICN_BASE_URL=https://api.waqi.info
AQICN_API_KEY=
OVERPASS_BASE_URL=https://overpass-api.de/api/interpreter

# Портал открытых данных Москвы — https://data.mos.ru/developers
# Docker: ключ подхватывается из этого файла (env_file). Запуск без Docker: экспортируйте переменные
# или укажите их в Run Configuration IDE — Spring сам .env не читает.
MOS_DATA_BASE_URL=https://apidata.mos.ru
MOS_DATA_API_KEY=
# Числовой ID набора — см. URL /opendata/{id}/ на data.mos.ru (по умолчанию 2756)
MOS_DATA_WIFI_DATASET_ID=2756
# Справочник кинотеатров — по умолчанию 495 (data.mos.ru/opendata/495)
MOS_DATA_CINEMA_DATASET_ID=495
# Благоустройство жилой застройки — 62961; фильтр YearOfWork >= min year; лимит строк API
MOS_DATA_LANDSCAPING_DATASET_ID=62961
MOS_DATA_LANDSCAPING_MIN_YEAR=2024
MOS_DATA_LANDSCAPING_MAX_ROWS=1500
# Каталог для одноразовых снимков 62961 (строки API + точки с координатами); в Docker см. volume в docker-compose
MOS_DATA_LANDSCAPING_SNAPSHOT_ENABLED=true
MOS_DATA_LANDSCAPING_SNAPSHOT_DIR=./data/mos-landscaping-snapshots

# Геокодирование адресов кинотеатров (Nominatim), если в API data.mos.ru нет координат
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_ENABLED=true

# Cache TTLs
CACHE_TTL_AQICN=15m
CACHE_TTL_OVERPASS=6h

# GET /api/v1/debug/warmup-status — в проде лучше false
DEBUG_WARMUP_STATUS_ENABLED=true
