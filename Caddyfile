# Caddy: Let's Encrypt (авто) для публичного домена, HTTP для localhost.
# Переменная CADDY_SITE_LABELS: одно имя или несколько через запятую.
# Для кириллического .рф укажите ОБА: UTF-8 и punycode — иначе часть клиентов попадёт не в тот site block.
# Пример: мосдомэксперт.рф,xn--d1acogbkbkkdep1l.xn--p1ai
# Старый CADDY_DOMAIN подхватывается из docker-compose, если CADDY_SITE_LABELS не задан.
{$CADDY_SITE_LABELS:localhost} {
	encode gzip

	handle /api/* {
		reverse_proxy app:8080 {
			transport http {
				dial_timeout 75s
				read_timeout 600s
			}
		}
	}

	handle {
		reverse_proxy frontend:80
	}
}
