# Caddy: Let's Encrypt (авто) для публичного домена, HTTP для localhost.
# Переменная: CADDY_DOMAIN (например мосдомэксперт.рф). Контакт ACME: см. https://caddyserver.com/docs/caddyfile/options#email
{$CADDY_DOMAIN:localhost} {
	encode gzip

	handle /api/* {
		reverse_proxy app:8080
	}

	handle {
		reverse_proxy frontend:80
	}
}
